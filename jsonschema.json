{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "att_data",
  "title": "AttestationData",
  "type": "object",
  "required": ["repository", "range", "generated_at", "config", "commits", "pull_requests"],
  "additionalProperties": false,
  "properties": {
    "repository": {
      "type": "string",
      "description": "The repository in 'owner/repo' format"
    },
    "range": {
      "type": "object",
      "required": ["base", "current"],
      "additionalProperties": false,
      "properties": {
        "base": {
          "type": "string",
          "description": "Base tag or ref"
        },
        "base_sha": {
          "type": "string",
          "description": "Resolved SHA for the base ref"
        },
        "current": {
          "type": "string",
          "description": "Current tag or ref"
        },
        "current_sha": {
          "type": "string",
          "description": "Resolved SHA for the current ref"
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this data was generated"
    },
    "config": {
      "type": "object",
      "required": ["exemptions"],
      "additionalProperties": false,
      "properties": {
        "exemptions": {
          "type": "object",
          "required": ["serviceAccounts", "filePaths", "fileNames"],
          "additionalProperties": false,
          "properties": {
            "serviceAccounts": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Regex patterns matching service account logins to exempt"
            },
            "filePaths": {
              "type": "array",
              "items": { "type": "string" },
              "description": "File paths to exempt from review requirements"
            },
            "fileNames": {
              "type": "array",
              "items": { "type": "string" },
              "description": "File names to exempt from review requirements"
            }
          }
        }
      }
    },
    "commits": {
      "type": "array",
      "items": { "$ref": "#/$defs/CommitData" },
      "description": "All commits in the range, in reverse chronological order"
    },
    "pull_requests": {
      "type": "object",
      "description": "Pull requests keyed by PR number (as string)",
      "additionalProperties": { "$ref": "#/$defs/PRDetails" }
    }
  },
  "$defs": {
    "UserIdentity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "git_name": {
          "type": "string",
          "description": "Git author name"
        },
        "git_email": {
          "type": "string",
          "description": "Git author email"
        },
        "login": {
          "type": "string",
          "description": "GitHub login handle"
        },
        "user_id": {
          "type": "integer",
          "description": "GitHub user ID"
        },
        "web_url": {
          "type": "string",
          "format": "uri",
          "description": "GitHub profile URL"
        }
      }
    },
    "CommitData": {
      "type": "object",
      "required": ["sha", "parent_shas", "author", "date", "message", "changed_files", "pr_numbers"],
      "additionalProperties": false,
      "properties": {
        "sha": {
          "type": "string",
          "description": "Full commit SHA"
        },
        "parent_shas": {
          "type": "array",
          "items": { "type": "string" },
          "description": "SHAs of parent commits"
        },
        "author": { "$ref": "#/$defs/UserIdentity" },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 commit timestamp"
        },
        "message": {
          "type": "string",
          "description": "Full commit message"
        },
        "changed_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "File paths changed in this commit"
        },
        "pr_numbers": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "PR numbers this commit is associated with"
        }
      }
    },
    "CommitInfo": {
      "type": "object",
      "required": ["sha", "parent_shas", "author", "date", "message"],
      "additionalProperties": false,
      "description": "Commit as it appears nested inside a PR (no changed_files or pr_numbers)",
      "properties": {
        "sha": {
          "type": "string"
        },
        "parent_shas": {
          "type": "array",
          "items": { "type": "string" }
        },
        "author": { "$ref": "#/$defs/UserIdentity" },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "Approval": {
      "type": "object",
      "required": ["user", "approved_at"],
      "additionalProperties": false,
      "properties": {
        "user": { "$ref": "#/$defs/UserIdentity" },
        "approved_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the approval was given"
        }
      }
    },
    "PRDetails": {
      "type": "object",
      "required": ["number", "url", "title", "author", "state", "merged_at", "approvals", "commits"],
      "additionalProperties": false,
      "properties": {
        "number": {
          "type": "integer",
          "description": "PR number"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "GitHub PR URL"
        },
        "title": {
          "type": "string",
          "description": "PR title"
        },
        "author": { "$ref": "#/$defs/UserIdentity" },
        "state": {
          "type": "string",
          "enum": ["open", "closed"],
          "description": "PR state"
        },
        "merged_at": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ],
          "description": "ISO 8601 timestamp when the PR was merged, or null if not merged"
        },
        "approvals": {
          "type": "array",
          "items": { "$ref": "#/$defs/Approval" },
          "description": "List of approvals on this PR"
        },
        "commits": {
          "type": "array",
          "items": { "$ref": "#/$defs/CommitInfo" },
          "description": "Commits included in this PR"
        }
      }
    }
  }
}
