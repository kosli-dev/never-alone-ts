{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "att_data",
  "title": "CommitAttestation",
  "type": "object",
  "required": ["commit_sha", "repository", "generated_at", "commit", "pull_requests"],
  "additionalProperties": false,
  "properties": {
    "commit_sha": {
      "type": "string",
      "description": "Full SHA of the commit this attestation covers"
    },
    "repository": {
      "type": "string",
      "description": "The repository in 'owner/repo' format"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this data was generated"
    },
    "commit": { "$ref": "#/$defs/CommitSummary" },
    "pull_requests": {
      "type": "array",
      "items": { "$ref": "#/$defs/PRSummary" },
      "description": "PRs associated with this commit"
    }
  },
  "$defs": {
    "UserIdentity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "git_name": {
          "type": "string",
          "description": "Git author name"
        },
        "git_email": {
          "type": "string",
          "description": "Git author email"
        },
        "login": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ],
          "description": "GitHub login handle, or null if unresolvable"
        },
        "user_id": {
          "oneOf": [
            { "type": "integer" },
            { "type": "null" }
          ],
          "description": "GitHub user ID"
        },
        "web_url": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ],
          "description": "GitHub profile URL"
        }
      }
    },
    "Approval": {
      "type": "object",
      "required": ["user", "approved_at"],
      "additionalProperties": false,
      "properties": {
        "user": { "$ref": "#/$defs/UserIdentity" },
        "approved_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when the approval was given"
        }
      }
    },
    "PRCommitSummary": {
      "type": "object",
      "required": ["sha", "parent_shas", "author", "date", "message"],
      "additionalProperties": false,
      "properties": {
        "sha": { "type": "string" },
        "parent_shas": {
          "type": "array",
          "items": { "type": "string" }
        },
        "author": { "$ref": "#/$defs/UserIdentity" },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "message": { "type": "string" }
      }
    },
    "CommitSummary": {
      "type": "object",
      "required": ["sha", "parent_shas", "author", "date", "message", "changed_files"],
      "additionalProperties": false,
      "properties": {
        "sha": {
          "type": "string",
          "description": "Full commit SHA"
        },
        "parent_shas": {
          "type": "array",
          "items": { "type": "string" },
          "description": "SHAs of parent commits"
        },
        "author": { "$ref": "#/$defs/UserIdentity" },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 commit timestamp"
        },
        "message": {
          "type": "string",
          "description": "Full commit message"
        },
        "changed_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "File paths changed in this commit"
        }
      }
    },
    "PRSummary": {
      "type": "object",
      "required": ["number", "url", "title", "state", "merged_at", "author", "approvals", "pr_commits"],
      "additionalProperties": false,
      "properties": {
        "number": {
          "type": "integer",
          "description": "PR number"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "GitHub PR URL"
        },
        "title": {
          "type": "string",
          "description": "PR title"
        },
        "state": {
          "type": "string",
          "enum": ["open", "closed"],
          "description": "PR state"
        },
        "merged_at": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ],
          "description": "ISO 8601 timestamp when the PR was merged, or null if not merged"
        },
        "author": { "$ref": "#/$defs/UserIdentity" },
        "approvals": {
          "type": "array",
          "items": { "$ref": "#/$defs/Approval" },
          "description": "List of approvals on this PR"
        },
        "pr_commits": {
          "type": "array",
          "items": { "$ref": "#/$defs/PRCommitSummary" },
          "description": "Commits on the PR branch"
        }
      }
    }
  }
}
