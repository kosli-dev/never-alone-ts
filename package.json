{
  "name": "never-alone",
  "version": "1.0.0",
  "description": "Source Code Review Verification Tool",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "scr-verify": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:rego": "opa test four-eyes.rego four-eyes_test.rego -v"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
